COMPOSE_PROJECT_NAME=mock-machine

POSTGRES_DB=mock_machine
POSTGRES_USER=mock_machine
POSTGRES_PASSWORD=mock_machine_dev_password
DATABASE_URL=postgres://mock_machine:mock_machine_dev_password@postgres:5432/mock_machine

REDIS_URL=redis://redis:6379/0
# Optional frontend override. By default the admin panel derives Socket.IO origin
# from VITE_API_BASE_URL in dev and from the current origin behind nginx.
VITE_SOCKET_IO_URL=

MINIO_ROOT_USER=mock_machine_root
MINIO_ROOT_PASSWORD=mock_machine_root_password
MINIO_BUCKET=mock-machine-files
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=mock_machine_app
MINIO_SECRET_KEY=mock_machine_app_secret
S3_ENDPOINT=http://minio:9000

BACKEND_PORT=8080
FRONTEND_PORT=5173
NGINX_PORT=8088
